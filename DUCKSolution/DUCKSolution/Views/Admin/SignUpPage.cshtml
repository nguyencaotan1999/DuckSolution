@model DUCKSolution.ViewModels.SignUpViewModel
@{
    ViewData["Title"] = "Đăng ký";
}

<div class="auth-page d-flex justify-content-center align-items-start py-5">
    <div class="card shadow-sm auth-card">
        <div class="card-body p-4 p-md-5">
            <h1 class="h4 fw-bold text-center mb-4">Đăng ký tài khoản</h1>

            @* Renders model-level errors (e.g. "email already exists" added in the controller) *@
            <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

            <form asp-controller="Admin" asp-action="SignUpPage" method="post" novalidate>
                @Html.AntiForgeryToken()

                <div class="mb-3">
                    <label asp-for="UserName" class="form-label"></label>
                    <input asp-for="UserName" class="form-control" autocomplete="username" />
                    <span asp-validation-for="UserName" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="UserEmail" class="form-label"></label>
                    <input asp-for="UserEmail" class="form-control" type="email" autocomplete="email" />
                    <span asp-validation-for="UserEmail" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="UserPassword" class="form-label"></label>
                    <input asp-for="UserPassword" class="form-control" autocomplete="new-password" />
                    <span asp-validation-for="UserPassword" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="ConfirmPassword" class="form-label"></label>
                    <input asp-for="ConfirmPassword" class="form-control" autocomplete="new-password" />
                    <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                </div>

                <button type="submit" class="btn btn-primary w-100">Đăng ký</button>

                <p class="text-center small mt-3 mb-0">
                    Đã có tài khoản?
                    <a asp-controller="Admin" asp-action="SignInPage">Đăng nhập</a>
                </p>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
