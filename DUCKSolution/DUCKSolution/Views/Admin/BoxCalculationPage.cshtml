@{
    ViewData["Title"] = "Home Page";
}

<link rel="stylesheet" href="~/css/export-calculation.css" asp-append-version="true" />

@* Anti-forgery token: read by box-calculation.ts and sent as the
   RequestVerificationToken header when POSTing to /Admin/SaveBoxData. *@
@Html.AntiForgeryToken()

<div class="cage-page">
    <header class="cage-page__header">
        <div class="row">
            <div class="col-6">
                <h1 class="cage-page__title">Bảng tính Vịt xuất chuồng</h1>
                <p class="cage-page__subtitle">Nhập số lồng và số ký cho từng dòng — tổng được tính tự động.</p>
            </div>
            <div class="col-6">
                <div class="row">
                    <div class="col-6"><input id="orderCode" class="form-control" type="text" name="name" value="" placeholder="Nhập mã đơn hàng....." maxlength="15" autocomplete="off" /></div>
                    <div class="col-6"><input id="fetchDataBtn" class="btn btn-primary" type="button" value="Lấy dữ liệu" /></div>
                </div>
                
            </div>
        </div>
        
    </header>
    <div id="carouselExampleDark" class="carousel carousel-dark slide" data-bs-ride="carousel" >
        <div class="carousel-indicators">
            <button type="button" data-bs-target="#carouselExampleDark" data-bs-slide-to="0" class="active" aria-current="true" aria-label="Slide 1"></button>
            <button type="button" data-bs-target="#carouselExampleDark" data-bs-slide-to="1" aria-label="Slide 2"></button>
            <button type="button" data-bs-target="#carouselExampleDark" data-bs-slide-to="2" aria-label="Slide 3"></button>
        </div>
        <div class="carousel-inner" >
            <div class="carousel-item active" data-bs-interval="10000">
                <img src="./img/141e7f55fab17bef22a0.jpg" class="d-block w-100" alt="...">
                <div class="carousel-caption d-none d-md-block">
                    <h5>First slide label</h5>
                    <p>Some representative placeholder content for the first slide.</p>
                </div>
            </div>
            <div class="carousel-item" data-bs-interval="2000">
                <img src="./img/e5d14dabc84f4911105e.jpg" class="d-block w-100" alt="...">
                <div class="carousel-caption d-none d-md-block">
                    <h5>Second slide label</h5>
                    <p>Some representative placeholder content for the second slide.</p>
                </div>
            </div>
            <div class="carousel-item">
                <img src="img/e71dd55253b6d2e88ba7.jpg" class="d-block w-100" alt="...">
                <div class="carousel-caption d-none d-md-block">
                    <h5>Third slide label</h5>
                    <p>Some representative placeholder content for the third slide.</p>
                </div>
            </div>
        </div>
        <button class="carousel-control-prev" type="button" data-bs-target="#carouselExampleDark" data-bs-slide="prev">
            <span class="carousel-control-prev-icon" aria-hidden="true"></span>
            <span class="visually-hidden">Previous</span>
        </button>
        <button class="carousel-control-next" type="button" data-bs-target="#carouselExampleDark" data-bs-slide="next">
            <span class="carousel-control-next-icon" aria-hidden="true"></span>
            <span class="visually-hidden">Next</span>
        </button>
    </div>
    
    @* Hidden until a successful fetch; box-calculation.ts toggles d-none. *@
    <div id="boxPanel" class="row g-4 d-none">
        <div class="col-12 col-lg-8">
            <div class="cage-toolbar">
                <button id="boxAddRowBtn" class="btn btn-primary" type="button">
                    <i class="bi bi-plus-lg"></i> Thêm dòng
                </button>
                <span class="cage-toolbar__hint">Số dòng: <strong id="boxRowCount">0</strong></span>
            </div>

            <div class="cage-table-wrap">
                <table class="table table-bordered table-hover cage-table mb-0">
                    <thead>
                        <tr>
                            <th class="cage-col-no" scope="col">STT</th>
                            <th scope="col">Số Lồng</th>
                            <th scope="col">Số Ký</th>
                            <th class="cage-col-action" scope="col"></th>
                        </tr>
                    </thead>
                    <tbody id="boxTableBody"></tbody>
                </table>
            </div>
        </div>

        <div class="col-12 col-lg-4">
            <div class="cage-summary">
                <h2 class="cage-summary__title">Tổng kết</h2>

                <div class="cage-summary__field">
                    <label for="totalBox" class="cage-summary__label">Tổng số Lồng</label>
                    <input id="totalBox" class="form-control cage-summary__value" type="number" value="0"
                           readonly />
                </div>

                <div class="cage-summary__field">
                    <label for="totalBoxKg" class="cage-summary__label">Tổng số Ký</label>
                    <input id="totalBoxKg" class="form-control cage-summary__value" type="number" value="0" readonly />
                </div>
                <div class="cage-summary__field">
                    <input id="saveDataBtn" class="btn btn-primary" type="button" value="Lưu dữ liệu" />
                </div>
            </div>
        </div>
    </div>
</div>

@* Toast host (Bootstrap toasts are injected here by box-calculation.ts) *@
<div id="toastContainer" class="toast-container position-fixed bottom-0 end-0 p-3"></div>
